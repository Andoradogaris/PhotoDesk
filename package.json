{
  "name": "photo-desk",
  "version": "0.1.0",
  "description": "Application desktop pour organiser, trier et éditer des photos et vidéos.",
  "main": "out/main/index.js",
  "author": "Codex",
  "license": "MIT",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit --composite false --incremental false -p tsconfig.json && tsc --noEmit --composite false --incremental false -p tsconfig.web.json",
    "test": "tsc -p tsconfig.test.json && node --test .test-dist/tests/file-system-utils.test.js",
    "check": "npm run typecheck && npm test && npm run build",
    "start": "electron .",
    "desktop": "npm run build && electron .",
    "preview": "electron-vite preview",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "exifr": "^7.1.3",
    "ffprobe-static": "^3.1.0",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@electron-toolkit/tsconfig": "^1.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^42.4.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.codex.photodesk",
    "productName": "Photo Desk",
    "files": [
      "out/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "**/node_modules/sharp/**/*",
      "**/node_modules/@img/**/*",
      "**/node_modules/ffprobe-static/**/*"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    }
  }
}
